# Copy to .env and fill in. NEVER commit .env.

NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Financial Core (game-server calls /api/v1/internal/* over the internal network).
FC_BASE_URL=http://127.0.0.1:3000
FC_INTERNAL_TOKEN=

# drand multi-node URLs (Commit-Reveal triple-mix). Comma-separated.
DRAND_URLS=https://api.drand.sh,https://api2.drand.sh,https://api3.drand.sh
DRAND_TIMEOUT_MS=5000

# AWS KMS for the third randomness source. Empty = crypto.randomBytes
# (local dev only — production MUST set a real KMS key id).
KMS_KEY_ID=
