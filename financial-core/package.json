{
  "name": "@fairplay/financial-core",
  "version": "0.1.0",
  "private": true,
  "description": "FairPlay Financial Core: wallets, ledger, settlement, underwriting, jackpot, reinsurance. The single source of truth for all fund movements.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0 <21",
    "npm": ">=10.0.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand",
    "mongo:rs:start": "node scripts/mongo-rs-start.mjs",
    "mongo:rs:stop": "node scripts/mongo-rs-stop.mjs",
    "ci": "npm run lint && npm run typecheck && npm run test"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.2",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "redlock": "^5.0.0-beta.2",
    "uuid": "^11.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.17.10",
    "@eslint/js": "^9.17.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "typescript-eslint": "^8.18.2",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.2",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
