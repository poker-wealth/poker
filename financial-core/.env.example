# Copy to .env and fill in. NEVER commit .env.

# Runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# MongoDB Replica Set (single-node RS for local dev — Replica Set required for transactions)
MONGO_URI=mongodb://127.0.0.1:27017/fairplay-fc?replicaSet=rs0&directConnection=true
MONGO_DB_NAME=fairplay-fc

# Redis (Sentinel in prod, single instance ok for local dev)
REDIS_URL=redis://127.0.0.1:6379

# JWT (dataScopeMiddleware extracts leagueId from JWT only)
JWT_SECRET=change-me-locally-only
JWT_ISSUER=fairplay
JWT_AUDIENCE=fairplay-fc

# Telegram Bot (CB6 alerts and other ops notifications)
TG_BOT_TOKEN=
TG_OPS_CHAT_ID=

# Internal-API shared secret (game-server → FC). Generate with:
#   openssl rand -hex 32
# Required to call /api/v1/internal/* endpoints. M2 W3+ replaces with service JWT.
INTERNAL_API_TOKEN=

# TRC20 / Tron (Day 4 deposit listener)
TRON_FULLNODE_URL=https://api.trongrid.io
TRON_USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
TRON_DEPOSIT_CONFIRMATIONS=20

# HD wallet (master key MUST live in HSM in production — local dev only)
HD_MASTER_SEED_HEX=
